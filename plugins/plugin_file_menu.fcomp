{"name": "MENU", "html": "<button style=\"background:#333;border:1px solid #555;color:#ccc;padding:4px 10px;border-radius:3px;font-size:11px;cursor:pointer;\" onclick=\"var m=this.nextElementSibling,d=m.style.display==='none';document.querySelectorAll('.fdrop').forEach(x=>x.style.display='none');m.style.display=d?'block':'none';event.stopPropagation()\">☰</button><div class=\"fdrop\" style=\"display:none;position:absolute;top:100%;left:0;background:#222;border:1px solid #444;min-width:120px;z-index:1001;\"><div style=\"padding:6px 10px;cursor:pointer;border-bottom:1px solid #333;font-size:10px;color:#ccc;\">📄 Новый</div><div style=\"padding:6px 10px;cursor:pointer;border-bottom:1px solid #333;font-size:10px;color:#ccc;\">📂 Открыть</div><div style=\"padding:6px 10px;cursor:pointer;border-bottom:1px solid #333;font-size:10px;color:#ccc;\">💾 Сохранить</div><div style=\"padding:6px 10px;cursor:pointer;border-bottom:1px solid #333;font-size:10px;color:#ccc;\">📥 Импорт</div><div style=\"padding:6px 10px;font-size:10px;color:#ccc;\">📤 Экспорт</div></div>", "ai": "Меню", "w": 50, "ht": 28}
