{"name": "TOGGLE", "html": "<div class=\"toggle-root\" style=\"display:flex;align-items:center;gap:8px;padding:4px;width:100%;height:100%;box-sizing:border-box;justify-content:center;\"><div class=\"toggle-track\" style=\"width:44px;height:24px;background:#555;border-radius:12px;cursor:pointer;position:relative;\"><div class=\"toggle-thumb\" style=\"width:20px;height:20px;background:#fff;border-radius:50%;position:absolute;top:2px;left:2px;transition:0.2s;\"></div></div><span class=\"toggle-label\" style=\"font-size:11px;color:#888;\">OFF</span></div>", "ai": "Переключатель ON/OFF.", "w": 90, "ht": 35}
