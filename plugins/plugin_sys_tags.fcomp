{
  "name": "TAGS",
  "html": "<div class=\"tags-root\" style=\"display:flex;flex-direction:column;width:100%;height:100%;background:#111;border:1px solid #333;border-radius:4px;box-sizing:border-box;\"><div style=\"font-size:9px;color:#555;padding:4px 8px;border-bottom:1px solid #333;background:#1a1a1a;\">TAGS</div><div class=\"tags-list\" style=\"flex:1;padding:6px;overflow:auto;display:flex;flex-wrap:wrap;gap:4px;align-content:flex-start;\"><span style=\"background:#007acc;color:#fff;padding:3px 8px;font-size:9px;border-radius:10px;cursor:pointer;\">#important</span><span style=\"background:#0a5;color:#fff;padding:3px 8px;font-size:9px;border-radius:10px;cursor:pointer;\">#todo</span><span style=\"background:#a50;color:#fff;padding:3px 8px;font-size:9px;border-radius:10px;cursor:pointer;\">#recipe</span><span style=\"background:#505;color:#fff;padding:3px 8px;font-size:9px;border-radius:10px;cursor:pointer;\">#draft</span><span style=\"background:#333;color:#aaa;padding:3px 8px;font-size:9px;border-radius:10px;cursor:pointer;\">+</span></div></div>",
  "ai": "Облако тегов. Клик по тегу - выбор. + для добавления.",
