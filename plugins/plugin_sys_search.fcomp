  "html": "<div class=\"search-root\" style=\"display:flex;flex-direction:column;width:100%;height:100%;box-sizing:border-box;\"><input class=\"search-input\" type=\"text\" placeholder=\"Поиск...\" style=\"background:#000;color:#0f0;border:1px solid #0f0;font-family:Consolas;font-size:10px;padding:6px;border-radius:4px 4px 0 0;outline:none;width:100%;box-sizing:border-box;\"><div class=\"search-results\" style=\"flex:1;background:#000;border:1px solid #0f0;border-top:none;font-size:9px;font-family:Consolas;color:#888;overflow:auto;padding:4px;\"><div style=\"color:#555;\">Результаты...</div></div></div>",
